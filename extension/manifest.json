{
  "manifest_version": 3,
  "name": "ChatGPT Usage Tracker",
  "version": "1.0.1",
  "description": "Tracks Custom GPT usage across agents for analytics and reporting",
  "permissions": [
    "storage",
    "nativeMessaging",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.jpg",
    "48": "icons/icon48.jpg",
    "128": "icons/icon128.jpg"
  }
}
